# AI API Key (Required)
AI_BAILIAN_API_KEY=your_api_key_here

# AI Model (Optional, default: qwen-plus)
# AI_MODEL=qwen-max
# Text provider (Optional, default: spring-ai)
# APP_AI_TEXT_PROVIDER=responses
# Responses API (Optional, only needed when APP_AI_TEXT_PROVIDER=responses)
# APP_AI_RESPONSES_BASE_URL=https://api.openai.com
# APP_AI_RESPONSES_PATH=/v1/responses
# AI_RESPONSES_API_KEY=your_responses_api_key_here
# APP_AI_RESPONSES_MODEL=gpt-5.4
# APP_AI_RESPONSES_TEMPERATURE=0.2
# Structured output retries (Optional, default: 2)
# APP_AI_STRUCTURED_MAX_ATTEMPTS=2
# Include last parser error in retry prompt (Optional, default: true)
# APP_AI_STRUCTURED_INCLUDE_LAST_ERROR=true

# Optional: Override defaults
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=interview_guide
